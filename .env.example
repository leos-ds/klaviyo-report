# Klaviyo Agency Toolkit — environment variables
#
# Copy to .env and fill in real values.
# .env is gitignored — never commit it.
# Get current keys from the agency 1Password vault: agency/klaviyo
#
# Each key follows the format pk_XXXXXX... (Klaviyo Private API key)
# If a key was exposed (chat, screenshot, email), rotate it in Klaviyo
# Settings → API Keys → Generate new → revoke old.

# ===== Klaviyo per-client keys =====
KLAVIYO_OUTDOORLINE_KEY=
KLAVIYO_KREKRY_CZ_KEY=
KLAVIYO_KREKRY_COM_KEY=
KLAVIYO_KRUSCHIKI_KEY=
KLAVIYO_KINTSUGI_KEY=
KLAVIYO_OURTE_KEY=
KLAVIYO_MADE_IN_JAPAN_KEY=

# ===== ClickUp =====
# Personal API token from https://app.clickup.com/settings/apps
# Required scopes: read tasks, write tasks
CLICKUP_API_TOKEN=

# ===== Slack (optional, for weekly digest) =====
# Incoming webhook URL for #email-marketing-team channel
SLACK_WEBHOOK_URL=

# ===== Logging =====
LOG_LEVEL=INFO
